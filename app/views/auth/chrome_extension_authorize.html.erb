<% content_for :title, "Authorize Sourcy Chrome Extension" %>

<div class="oauth-container">
  <div class="oauth-card">
    <!-- Header -->
    <div class="oauth-header">
      <div class="oauth-logo">
        <%= inline_svg_tag("logo.svg", class: "logo-icon") %>
      </div>
      <h1>Authorize Sourcy Chrome Extension</h1>
    </div>

    <!-- Extension Info -->
    <div class="extension-info">
      <div class="info-row">
        <span class="label">Extension:</span>
        <span class="value">Sourcy Chrome Extension</span>
      </div>
      <div class="info-row">
        <span class="label">Publisher:</span>
        <span class="value">Sourcy Inc.</span>
      </div>
      <div class="info-row">
        <span class="label">Version:</span>
        <span class="value">1.0.0</span>
      </div>
    </div>

    <!-- Permissions -->
    <div class="permissions-section">
      <h2>Permissions Requested</h2>
      <p class="permissions-description">
        This extension requests the following permissions:
      </p>

      <div class="permissions-list">
        <div class="permission-item">
          <div class="permission-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </div>
          <div class="permission-content">
            <h3>Extract Products</h3>
            <p>Extract product data from supported e-commerce sites</p>
          </div>
        </div>

        <div class="permission-item">
          <div class="permission-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <div class="permission-content">
            <h3>Access Your Account</h3>
            <p>Access your Sourcy account to sync extracted products</p>
          </div>
        </div>

        <div class="permission-item">
          <div class="permission-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <div class="permission-content">
            <h3>Secure Authentication</h3>
            <p>Use OAuth2 PKCE for secure authentication</p>
          </div>
        </div>
      </div>
    </div>

    <!-- User Info -->
    <div class="user-info">
      <div class="user-avatar">
        <%= current_user.name.first %>
      </div>
      <div class="user-details">
        <h3><%= current_user.name %></h3>
        <p><%= current_user.email %></p>
        <p class="account-name"><%= current_user.account.name %></p>
      </div>
    </div>

    <!-- Actions -->
    <div class="oauth-actions">
      <%= form_with url: chrome_extension_approve_path, method: :post, local: true do |f| %>
        <%= hidden_field_tag :session_id, params[:session_id] %>
        <%= hidden_field_tag :redirect_uri, @auth_session[:redirect_uri] %>
        <%= hidden_field_tag :state, @auth_session[:state] %>

        <%= f.submit "Authorize", class: "btn btn-primary btn-block" %>
      <% end %>

      <%= form_with url: chrome_extension_deny_path, method: :post, local: true do |f| %>
        <%= hidden_field_tag :session_id, params[:session_id] %>
        <%= hidden_field_tag :redirect_uri, @auth_session[:redirect_uri] %>
        <%= hidden_field_tag :state, @auth_session[:state] %>

        <%= f.submit "Cancel", class: "btn btn-secondary btn-block" %>
      <% end %>
    </div>

    <!-- Security Notice -->
    <div class="security-notice">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <p>
        <strong>Security Note:</strong> This authorization is secure and uses OAuth2 PKCE.
        Your credentials are never shared with the extension.
      </p>
    </div>
  </div>
</div>

<style>
  .oauth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 20px;
  }

  .oauth-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 480px;
    width: 100%;
    padding: 40px;
  }

  .oauth-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .oauth-logo {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .oauth-logo svg {
    width: 32px;
    height: 32px;
    color: white;
  }

  .oauth-header h1 {
    font-size: 24px;
    font-weight: 700;
    color: #1a202c;
    margin: 0;
  }

  .extension-info {
    background: #f7fafc;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 32px;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #e2e8f0;
  }

  .info-row:last-child {
    border-bottom: none;
  }

  .info-row .label {
    font-weight: 500;
    color: #718096;
  }

  .info-row .value {
    font-weight: 600;
    color: #2d3748;
  }

  .permissions-section {
    margin-bottom: 32px;
  }

  .permissions-section h2 {
    font-size: 18px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 8px;
  }

  .permissions-description {
    color: #718096;
    font-size: 14px;
    margin-bottom: 20px;
  }

  .permissions-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .permission-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: #f7fafc;
    border-radius: 8px;
  }

  .permission-icon {
    width: 40px;
    height: 40px;
    background: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #667eea;
    flex-shrink: 0;
  }

  .permission-content h3 {
    font-size: 14px;
    font-weight: 600;
    color: #2d3748;
    margin: 0 0 4px 0;
  }

  .permission-content p {
    font-size: 13px;
    color: #718096;
    margin: 0;
  }

  .user-info {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
    border-radius: 12px;
    margin-bottom: 32px;
  }

  .user-avatar {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .user-details h3 {
    font-size: 16px;
    font-weight: 600;
    color: #1a202c;
    margin: 0 0 4px 0;
  }

  .user-details p {
    font-size: 14px;
    color: #718096;
    margin: 0 0 2px 0;
  }

  .user-details .account-name {
    font-size: 12px;
    color: #a0aec0;
  }

  .oauth-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .oauth-actions form {
    margin: 0;
  }

  .oauth-actions button {
    width: 100%;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .oauth-actions .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  }

  .oauth-actions .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(102, 126, 234, 0.5);
  }

  .oauth-actions .btn-secondary {
    background: white;
    color: #4a5568;
    border: 2px solid #e2e8f0;
  }

  .oauth-actions .btn-secondary:hover {
    border-color: #667eea;
    color: #667eea;
  }

  .security-notice {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: #fffaf0;
    border-left: 4px solid #ed8936;
    border-radius: 8px;
  }

  .security-notice svg {
    color: #ed8936;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .security-notice p {
    font-size: 13px;
    color: #4a5568;
    margin: 0;
    line-height: 1.6;
  }

  .security-notice strong {
    color: #2d3748;
  }
</style>

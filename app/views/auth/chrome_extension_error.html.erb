<% content_for :title, "Authorization Error" %>

<div class="error-container">
  <div class="error-card">
    <!-- Error Icon -->
    <div class="error-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    </div>

    <!-- Error Message -->
    <h1>Authorization Error</h1>
    <p class="error-message"><%= @error || "An unexpected error occurred during authorization." %></p>

    <!-- Explanation -->
    <div class="explanation">
      <h2>What happened?</h2>
      <p>
        The authorization session has expired or is invalid. This can happen if:
      </p>
      <ul>
        <li>You waited too long before completing the authorization</li>
        <li>The authorization was initiated from a different browser or device</li>
        <li>There was a network connectivity issue</li>
      </ul>
    </div>

    <!-- Actions -->
    <div class="error-actions">
      <%= link_to root_path, class: "btn btn-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Go to Dashboard
      <% end %>

      <button onclick="window.close()" class="btn btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
        Close Window
      </button>
    </div>

    <!-- Support -->
    <div class="support-section">
      <p>
        Need help? Visit our
        <%= link_to "Help Center", "https://docs.sourcy.com/help", target: "_blank", rel: "noopener" %>
        or
        <%= link_to "contact support", "mailto:support@sourcy.com" %>.
      </p>
    </div>
  </div>
</div>

<style>
  .error-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7fafc;
    padding: 20px;
  }

  .error-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    max-width: 480px;
    width: 100%;
    padding: 48px 40px;
    text-align: center;
  }

  .error-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    background: #fff5f5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-icon svg {
    width: 40px;
    height: 40px;
    color: #e53e3e;
  }

  .error-card h1 {
    font-size: 28px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 12px 0;
  }

  .error-message {
    font-size: 16px;
    color: #718096;
    line-height: 1.6;
    margin: 0 0 32px 0;
  }

  .explanation {
    text-align: left;
    background: #f7fafc;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 32px;
  }

  .explanation h2 {
    font-size: 16px;
    font-weight: 600;
    color: #2d3748;
    margin: 0 0 12px 0;
  }

  .explanation p {
    font-size: 14px;
    color: #4a5568;
    margin: 0 0 12px 0;
    line-height: 1.6;
  }

  .explanation ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .explanation ul li {
    font-size: 14px;
    color: #4a5568;
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
    margin-bottom: 8px;
  }

  .explanation ul li:last-child {
    margin-bottom: 0;
  }

  .explanation ul li::before {
    content: "•";
    position: absolute;
    left: 8px;
    color: #667eea;
    font-weight: 700;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .error-actions .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.2s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .error-actions .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  }

  .error-actions .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(102, 126, 234, 0.5);
  }

  .error-actions .btn-secondary {
    background: white;
    color: #4a5568;
    border: 2px solid #e2e8f0;
  }

  .error-actions .btn-secondary:hover {
    border-color: #667eea;
    color: #667eea;
  }

  .error-actions button {
    width: 100%;
    font-family: inherit;
  }

  .support-section {
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
  }

  .support-section p {
    font-size: 14px;
    color: #718096;
    margin: 0;
    line-height: 1.6;
  }

  .support-section a {
    color: #667eea;
    text-decoration: none;
    font-weight: 500;
  }

  .support-section a:hover {
    color: #764ba2;
    text-decoration: underline;
  }
</style>

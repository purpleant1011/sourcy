<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sourcy Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "application" %>
  </head>
  <body class="bg-gray-50">
    <div class="min-h-screen flex">
      <!-- 사이드바 -->
      <aside class="w-64 bg-white border-r border-gray-200 fixed h-full">
        <div class="p-6">
          <h1 class="text-2xl font-bold text-gray-900">Sourcy</h1>
        </div>

        <nav class="mt-6">
          <ul class="space-y-1 px-3">
            <li>
              <%= link_to admin_root_path,
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_root_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_root_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_root_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                  data: { turbo: true } do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                대시보드
              <% end %>
            </li>

            <li>
              <%= link_to admin_catalog_products_path,
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_catalog_products_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
                제품
              <% end %>
            </li>

            <li>
              <%= link_to admin_marketplace_listings_path,
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_marketplace_listings_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                리스팅
              <% end %>
            </li>

            <li>
              <%= link_to admin_settlements_path,
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_settlements_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                </svg>
                정산
              <% end %>
            </li>
          </ul>
            <li>
              <%= link_to admin_settings_path,
                  class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{current_page?(admin_settings_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-700 hover:bg-gray-100'}",
                  data: { turbo: true } do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                설정
              <% end %>
            </li>
        </nav>

        <div class="absolute bottom-0 w-full p-4 border-t border-gray-200">
          <div class="text-xs text-gray-500">
            Account: <%= Current.account&.name || 'Not selected' %>
          </div>
        </div>
      </aside>

      <!-- 메인 컨텐츠 -->
      <main class="flex-1 ml-64">
        <div class="p-8">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>

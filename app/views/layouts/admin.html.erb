<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sourcy Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-100" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <!-- Top Bar -->
    <header class="fixed top-0 left-0 right-0 bg-white border-b border-gray-200 shadow-sm" style="height: 60px; z-index: 50;">
      <div class="flex items-center justify-between px-6" style="height: 60px;">
        <div class="flex items-center">
          <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
          </svg>
          <span class="text-lg font-bold text-gray-900">Sourcy Admin</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-gray-600"><%= Current.account&.name || 'Admin' %></span>
          <a href="/" class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-gray-600 bg-gray-100 rounded-md hover:bg-gray-200">
            로그아웃
          </a>
        </div>
      </div>
    </header>

    <!-- Sidebar -->
    <aside class="fixed left-0 bottom-0 overflow-y-auto" style="top: 60px; width: 240px; background-color: #1e293b; z-index: 40;">
      <nav class="py-4">
        <ul class="space-y-1 px-3">
          <li>
            <%= link_to admin_root_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path == admin_root_path ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              <span>대시보드</span>
            <% end %>
          </li>

          <li>
            <%= link_to admin_catalog_products_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/catalog_products') ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
              <span>제품</span>
            <% end %>
          </li>

          <li>
            <%= link_to admin_marketplace_listings_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/marketplace_listings') ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
              <span>리스팅</span>
            <% end %>
          </li>

          <li>
            <%= link_to admin_orders_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/orders') ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              <span>주문</span>
            <% end %>
          </li>

          <li>
            <%= link_to admin_settlements_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/settlements') ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
              <span>정산</span>
            <% end %>
          </li>

          <li>
            <%= link_to admin_settings_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/settings') ? 'bg-blue-600 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>설정</span>
            <% end %>
          </li>
        </ul>
      </nav>

      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-700">
        <div class="text-xs text-gray-400">
          Account: <%= Current.account&.name || 'Not selected' %>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main style="margin-left: 240px; padding-top: 60px; min-height: 100vh;">
      <% if flash[:notice] %>
        <div class="mx-8 mt-4 p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-800">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mx-8 mt-4 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <div class="p-8">
        <%= yield %>
      </div>
    </main>
  </body>
</html>

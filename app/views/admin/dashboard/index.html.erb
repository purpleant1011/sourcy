<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">대시보드</h1>
  <p class="mt-1 text-sm text-gray-500">Sourcy 관리 현황 요약</p>
</div>

<!-- 통계 카드 -->
<div class="grid grid-cols-4 gap-6 mb-8">
  <!-- 총 상품 수 -->
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500">총 제품</p>
        <p class="mt-2 text-3xl font-bold text-gray-900"><%= @total_products %></p>
      </div>
      <div class="bg-blue-100 rounded-lg p-3">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex items-center text-sm">
      <svg class="w-4 h-4 text-green-500 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
      </svg>
      <span class="text-green-600 font-medium">카탈로그</span>
    </div>
  </div>

  <!-- 라이브 리스팅 -->
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500">활성 리스팅</p>
        <p class="mt-2 text-3xl font-bold text-gray-900"><%= @active_listings %></p>
      </div>
      <div class="bg-green-100 rounded-lg p-3">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex items-center text-sm">
      <svg class="w-4 h-4 text-green-500 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
      </svg>
      <span class="text-green-600 font-medium">마켓플레이스</span>
    </div>
  </div>

  <!-- 오늘 주문 -->
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500">오늘 주문</p>
        <p class="mt-2 text-3xl font-bold text-gray-900"><%= @today_orders %></p>
      </div>
      <div class="bg-yellow-100 rounded-lg p-3">
        <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex items-center text-sm">
      <span class="text-gray-500">오늘 기준</span>
    </div>
  </div>

  <!-- 대기 작업 -->
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500">대기 작업</p>
        <p class="mt-2 text-3xl font-bold text-gray-900"><%= @pending_tasks %></p>
      </div>
      <div class="bg-red-100 rounded-lg p-3">
        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex items-center text-sm">
      <span class="text-gray-500">추출 대기</span>
    </div>
  </div>
</div>

<!-- 최근 주문 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">최근 주문</h2>
    <%= link_to '전체 보기', admin_orders_path, class: 'text-sm text-blue-600 hover:text-blue-800 font-medium' %>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문번호</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마켓</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">금액</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">날짜</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @recent_orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900">
                <%= link_to order.external_order_id, admin_order_path(order), class: 'text-blue-600 hover:text-blue-800' %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= order.marketplace_platform.humanize %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
              <%= number_to_currency(order.total_amount_krw / 100.0, precision: 0, unit: '₩') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% status_classes = case order.order_status
                when 'pending' then 'bg-gray-100 text-gray-800'
                when 'paid' then 'bg-blue-100 text-blue-800'
                when 'preparing' then 'bg-yellow-100 text-yellow-800'
                when 'shipped' then 'bg-indigo-100 text-indigo-800'
                when 'delivered' then 'bg-green-100 text-green-800'
                when 'canceled' then 'bg-red-100 text-red-800'
                when 'returned' then 'bg-purple-100 text-purple-800'
                else 'bg-gray-100 text-gray-800'
                end %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_classes %>">
                <%= order.order_status.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= order.created_at.strftime('%Y-%m-%d %H:%M') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to '상세', admin_order_path(order), class: 'text-blue-600 hover:text-blue-800' %>
            </td>
          </tr>
        <% end %>

        <% if @recent_orders.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              <p class="mt-2 text-sm text-gray-500">아직 주문이 없습니다</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

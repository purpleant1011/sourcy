<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">정산</h1>
    <p class="mt-2 text-gray-600">주문 기반 정산 내역 조회</p>
  </div>
  <%= link_to '리포트 보기', report_admin_settlements_path,
      class: 'inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>
</div>

<!-- 요약 카드 -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">총 주문 수</div>
    <div class="mt-2 text-3xl font-bold text-gray-900"><%= @summary[:total_count] %></div>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">총 매출액</div>
    <div class="mt-2 text-3xl font-bold text-green-600">
      <%= number_with_delimiter(@summary[:total_amount]) %>원
    </div>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">마켓별 주문</div>
    <div class="mt-2 text-sm text-gray-600">
      <% @summary[:by_platform].each do |platform, count| %>
        <span class="inline-flex items-center mr-2"><%= platform %>: <%= count %>건</span>
      <% end %>
    </div>
  </div>
</div>

<!-- 필터 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <%= form_with url: admin_settlements_path, method: :get, local: true,
      class: 'flex gap-4 items-end flex-wrap' do |f| %>
    <div class="flex-1 min-w-[160px]">
      <%= f.label :marketplace, '마켓플레이스', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :marketplace,
          options_for_select([['전체', ''], ['스마트스토어', 'naver_smartstore'], ['쿠팡', 'coupang'], ['11번가', 'eleven_street']], params[:marketplace]),
          {},
          class: 'block w-full rounded-md border-gray-300 shadow-sm sm:text-sm' %>
    </div>
    <div class="flex-1 min-w-[160px]">
      <%= f.label :start_date, '시작일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.date_field :start_date, value: params[:start_date], class: 'block w-full rounded-md border-gray-300 shadow-sm sm:text-sm' %>
    </div>
    <div class="flex-1 min-w-[160px]">
      <%= f.label :end_date, '종료일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.date_field :end_date, value: params[:end_date], class: 'block w-full rounded-md border-gray-300 shadow-sm sm:text-sm' %>
    </div>
    <div>
      <%= f.submit '검색', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700' %>
    </div>
  <% end %>
</div>

<!-- 주문 목록 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">주문 번호</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">마켓</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">주문일</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">금액</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= order.external_order_id %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= order.marketplace_platform %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= order.ordered_at&.strftime('%Y-%m-%d') %></td>
            <td class="px-6 py-4 text-right text-sm font-medium text-gray-900"><%= number_with_delimiter(order.total_amount_krw) %>원</td>
            <td class="px-6 py-4 text-sm">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                <%= order.order_status %>
              </span>
            </td>
          </tr>
        <% end %>
        <% if @orders.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">정산 내역이 없습니다.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

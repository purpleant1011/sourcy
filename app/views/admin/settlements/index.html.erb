<div class="mb-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">정산</h1>
    <p class="mt-2 text-gray-600">마켓플레이스 정산 관리</p>
  </div>
</div>

<!-- 정산 요약 카드 -->
<% if @summary[:total_count] > 0 %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 정산 건수</div>
      <div class="mt-2 text-3xl font-bold text-gray-900"><%= @summary[:total_count] %></div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 매출액</div>
      <div class="mt-2 text-3xl font-bold text-gray-900">
        <%= number_to_currency(@summary[:total_gross] / 100.0, precision: 0, unit: '₩') %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 수수료</div>
      <div class="mt-2 text-3xl font-bold text-red-600">
        <%= number_to_currency(@summary[:total_fees] / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">순수익</div>
      <div class="mt-2 text-3xl font-bold text-green-600">
        <%= number_to_currency(@summary[:total_net] / 100.0, precision: 0, unit: '₩') %>
      </div>
    </div>
  </div>
<% end %>

<!-- 필터 및 검색 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <%= form_with url: admin_settlements_path, method: :get, local: true,
      class: 'flex gap-4 items-end flex-wrap' do |f| %>
    <div class="flex-1 min-w-[200px]">
      <%= f.label :marketplace, '마켓플레이스', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :marketplace,
          options_for_select([
            ['전체', ''],
            ['네이버 스마트스토어', 'smart_store'],
            ['쿠팡', 'coupang'],
            ['G마켓', 'gmarket'],
            ['11번가', 'elevenst']
          ], params[:marketplace]),
          {},
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1 min-w-[200px]">
      <%= f.label :status, '상태', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :status,
          options_for_select(Settlement.statuses.map { |k, v| [k.humanize, k] }, params[:status]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1 min-w-[200px]">
      <%= f.label :start_date, '시작일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.date_field :start_date, value: params[:start_date],
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1 min-w-[200px]">
      <%= f.label :end_date, '종료일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.date_field :end_date, value: params[:end_date],
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div>
      <%= f.submit '검색', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700' %>
    </div>

    <div>
      <%= link_to '리포트', report_admin_settlements_path(start_date: params[:start_date], end_date: params[:end_date], marketplace: params[:marketplace]),
          class: 'px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>
    </div>

    <div>
      <%= link_to 'CSV 다운로드', export_admin_settlements_path(format: 'csv', start_date: params[:start_date], end_date: params[:end_date], marketplace: params[:marketplace]),
          class: 'px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>
    </div>
  <% end %>
</div>

<!-- 정산 목록 -->
<%= turbo_frame_tag 'settlements' do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">정산 ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문 번호</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마켓</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">정산일</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">총 금액</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">수수료</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">순수익</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
          </tr>
        </thead>

        <tbody class="bg-white divide-y divide-gray-200">
          <% @settlements.each do |settlement| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= settlement.id %></div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= settlement.order.order_number %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= settlement.marketplace.humanize %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= settlement.settlement_date %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
                <%= number_to_currency(settlement.gross_amount / 100.0, precision: 0, unit: '₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-red-600">
                <%= number_to_currency(settlement.total_fees / 100.0, precision: 0, unit: '-₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-green-600 font-medium">
                <%= number_to_currency(settlement.net_amount / 100.0, precision: 0, unit: '₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case settlement.status %>
                <% when :pending %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    대기
                  </span>
                <% when :paid %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    지급
                  </span>
                <% when :failed %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    실패
                  </span>
                <% end %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to '상세', admin_settlement_path(settlement),
                    class: 'text-blue-600 hover:text-blue-900',
                    data: { turbo: true } %>
              </td>
            </tr>
          <% end %>

          <% if @settlements.empty? %>
            <tr>
              <td colspan="9" class="px-6 py-12 text-center">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">정산 내역이 없습니다</h3>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- 페이지네이션 -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <div class="text-sm text-gray-700">
        총 <%= @settlements.total_count %>개 중 <%= @settlements.offset_value + 1 %> - <%= [@settlements.offset_value + @settlements.length, @settlements.total_count].min %>개 표시
      </div>

      <div class="flex gap-2">
        <% unless @settlements.first_page? %>
          <%= link_to '이전', url_for(page: params[:page].to_i - 1, status: params[:status], marketplace: params[:marketplace]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'settlements' } %>
        <% end %>

        <% unless @settlements.last_page? %>
          <%= link_to '다음', url_for(page: params[:page].to_i + 1, status: params[:status], marketplace: params[:marketplace]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'settlements' } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

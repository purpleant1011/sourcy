<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">정산 리포트</h1>
      <p class="mt-2 text-gray-600">기간별 정산 리포트</p>
    </div>

    <div class="flex gap-2">
      <%= link_to '목록으로', admin_settlements_path,
          class: 'px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>

      <%= link_to 'CSV 다운로드', export_admin_settlements_path(format: 'csv', start_date: @start_date, end_date: @end_date, marketplace: @marketplace),
          class: 'px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>
    </div>
  </div>
</div>

<!-- 리포트 필터 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <div class="text-sm font-medium text-gray-500">시작일</div>
      <div class="mt-1 text-sm text-gray-900"><%= @start_date %></div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">종료일</div>
      <div class="mt-1 text-sm text-gray-900"><%= @end_date %></div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">마켓플레이스</div>
      <div class="mt-1 text-sm text-gray-900">
        <%= @marketplace ? @marketplace.humanize : '전체' %>
      </div>
    </div>
  </div>
</div>

<!-- 리포트 요약 -->
<% if @report && @report[:summary] %>
  <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 주문 수</div>
      <div class="mt-2 text-3xl font-bold text-gray-900"><%= @report[:summary][:total_orders] %></div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 매출액</div>
      <div class="mt-2 text-3xl font-bold text-gray-900">
        <%= number_to_currency(@report[:summary][:gross_amount] / 100.0, precision: 0, unit: '₩') %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 수수료</div>
      <div class="mt-2 text-3xl font-bold text-red-600">
        <%= number_to_currency(@report[:summary][:total_fees] / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">총 세금</div>
      <div class="mt-2 text-3xl font-bold text-red-600">
        <%= number_to_currency(@report[:summary][:total_taxes] / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <div class="text-sm font-medium text-gray-500">순수익</div>
      <div class="mt-2 text-3xl font-bold text-green-600">
        <%= number_to_currency(@report[:summary][:net_amount] / 100.0, precision: 0, unit: '₩') %>
      </div>
    </div>
  </div>

  <!-- 마켓별 정산 -->
  <% if @report[:by_marketplace] && @report[:by_marketplace].any? %>
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">마켓별 정산</h2>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마켓플레이스</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">주문 수</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">총 매출액</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">수수료</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">세금</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">순수익</th>
            </tr>
          </thead>

          <tbody class="bg-white divide-y divide-gray-200">
            <% @report[:by_marketplace].each do |marketplace, data| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= marketplace.humanize %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
                  <%= data[:orders] %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
                  <%= number_to_currency(data[:gross_amount] / 100.0, precision: 0, unit: '₩') %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-red-600">
                  <%= number_to_currency(data[:total_fees] / 100.0, precision: 0, unit: '-₩') %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-red-600">
                  <%= number_to_currency(data[:total_taxes] / 100.0, precision: 0, unit: '-₩') %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium text-green-600">
                  <%= number_to_currency(data[:net_amount] / 100.0, precision: 0, unit: '₩') %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <!-- 상태별 정산 -->
  <% if @report[:by_status] && @report[:by_status].any? %>
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">상태별 정산</h2>

      <div class="space-y-4">
        <% @report[:by_status].each do |status, data| %>
          <div class="flex justify-between items-center">
            <div class="flex items-center">
              <% case status.to_sym %>
              <% when :pending %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 mr-2">
                  대기
                </span>
              <% when :paid %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 mr-2">
                  지급
                </span>
              <% when :failed %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 mr-2">
                  실패
                </span>
              <% end %>

              <span class="text-sm text-gray-900"><%= data[:count] %>건</span>
            </div>

            <div class="text-sm font-medium text-gray-900">
              <%= number_to_currency(data[:net_amount] / 100.0, precision: 0, unit: '₩') %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 일별 정산 추이 -->
  <% if @report[:by_date] && @report[:by_date].any? %>
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
      <h2 class="text-lg font-medium text-gray-900 mb-4">일별 정산 추이</h2>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">날짜</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">주문 수</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">총 매출액</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">순수익</th>
            </tr>
          </thead>

          <tbody class="bg-white divide-y divide-gray-200">
            <% @report[:by_date].sort.reverse.each do |date, data| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= date %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
                  <%= data[:orders] %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
                  <%= number_to_currency(data[:gross_amount] / 100.0, precision: 0, unit: '₩') %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium text-green-600">
                  <%= number_to_currency(data[:net_amount] / 100.0, precision: 0, unit: '₩') %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="bg-white rounded-lg shadow-sm p-12 border border-gray-200 text-center">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">리포트 데이터가 없습니다</h3>
    <p class="mt-1 text-sm text-gray-500">선택한 기간에 대한 정산 데이터가 없습니다.</p>
  </div>
<% end %>

<!-- 리포트 필터 폼 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mt-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">새 리포트 생성</h2>

  <%= form_with url: report_admin_settlements_path, method: :get, local: true do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
      <div>
        <%= f.label :start_date, '시작일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.date_field :start_date, value: @start_date,
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
      </div>

      <div>
        <%= f.label :end_date, '종료일', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.date_field :end_date, value: @end_date,
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
      </div>

      <div>
        <%= f.label :marketplace, '마켓플레이스', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.select :marketplace,
            options_for_select([
              ['전체', ''],
              ['네이버 스마트스토어', 'smart_store'],
              ['쿠팡', 'coupang'],
              ['G마켓', 'gmarket'],
              ['11번가', 'elevenst']
            ], @marketplace),
            {},
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
      </div>

      <div>
        <%= f.submit '리포트 생성', class: 'w-full px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700' %>
      </div>
    </div>
  <% end %>
</div>

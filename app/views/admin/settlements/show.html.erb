<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">정산 상세</h1>
      <p class="mt-2 text-gray-600">정산 정보 및 검증</p>
    </div>

    <div class="flex gap-2">
      <%= link_to '목록으로', admin_settlements_path,
          class: 'px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50' %>
    </div>
  </div>
</div>

<!-- 정산 요약 카드 -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">총 금액</div>
    <div class="mt-2 text-3xl font-bold text-gray-900">
      <%= number_to_currency(@settlement.gross_amount / 100.0, precision: 0, unit: '₩') %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">총 수수료</div>
    <div class="mt-2 text-3xl font-bold text-red-600">
      <%= number_to_currency(@settlement.total_fees / 100.0, precision: 0, unit: '-₩') %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">총 세금</div>
    <div class="mt-2 text-3xl font-bold text-red-600">
      <%= number_to_currency(@settlement.total_taxes / 100.0, precision: 0, unit: '-₩') %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="text-sm font-medium text-gray-500">순수익</div>
    <div class="mt-2 text-3xl font-bold text-green-600">
      <%= number_to_currency(@settlement.net_amount / 100.0, precision: 0, unit: '₩') %>
    </div>
  </div>
</div>

<!-- 정산 상세 정보 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">정산 정보</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <div class="text-sm font-medium text-gray-500">정산 ID</div>
      <div class="mt-1 text-sm text-gray-900"><%= @settlement.id %></div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">주문 번호</div>
      <div class="mt-1 text-sm text-gray-900">
        <%= link_to @order.order_number, admin_order_path(@order),
            class: 'text-blue-600 hover:text-blue-900' %>
      </div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">마켓플레이스</div>
      <div class="mt-1 text-sm text-gray-900"><%= @settlement.marketplace.humanize %></div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">정산일</div>
      <div class="mt-1 text-sm text-gray-900"><%= @settlement.settlement_date %></div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">상태</div>
      <div class="mt-1">
        <% case @settlement.status %>
        <% when :pending %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
            대기
          </span>
        <% when :paid %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            지급
          </span>
        <% when :failed %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
            실패
          </span>
        <% end %>
      </div>
    </div>

    <div>
      <div class="text-sm font-medium text-gray-500">검증 상태</div>
      <div class="mt-1">
        <% if @settlement.verified_at %>
          <% if @settlement.verification_passed %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              검증 완료
            </span>
          <% else %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
              검증 실패
            </span>
          <% end %>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
            미검증
          </span>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- 수수료 상세 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">수수료 상세</h2>

  <div class="space-y-4">
    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">커미션 수수료</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.commission_fee / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">결제 수수료</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.payment_fee / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">카테고리 수수료</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.category_fee / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">추가 수수료</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.additional_fee / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="border-t pt-4 mt-4">
      <div class="flex justify-between items-center">
        <div class="text-sm font-medium text-gray-900">총 수수료</div>
        <div class="text-lg font-bold text-red-600">
          <%= number_to_currency(@settlement.total_fees / 100.0, precision: 0, unit: '-₩') %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 세금 상세 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">세금 상세</h2>

  <div class="space-y-4">
    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">부가세 (VAT 10%)</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.vat / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">원천징수 (3.3%)</div>
      <div class="text-sm font-medium text-gray-900">
        <%= number_to_currency(@settlement.withholding_tax / 100.0, precision: 0, unit: '-₩') %>
      </div>
    </div>

    <div class="border-t pt-4 mt-4">
      <div class="flex justify-between items-center">
        <div class="text-sm font-medium text-gray-900">총 세금</div>
        <div class="text-lg font-bold text-red-600">
          <%= number_to_currency(@settlement.total_taxes / 100.0, precision: 0, unit: '-₩') %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 정산 검증 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">정산 검증</h2>

  <div class="mb-4">
    <p class="text-sm text-gray-500 mb-4">
      정산 금액을 재계산하여 기록된 정산 금액과 비교합니다. 1% 허용 오차 내에 있으면 검증됩니다.
    </p>

    <button id="verifyButton" type="button"
        class="px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700"
        data-action="click->settlement#verify"
        data-settlement-id="<%= @settlement.id %>">
      검증하기
    </button>
  </div>

  <div id="verificationResult" class="hidden">
    <!-- 검증 결과가 여기에 표시됩니다 -->
  </div>

  <% if @settlement.verified_at %>
    <div class="mt-4 p-4 rounded-md <%= @settlement.verification_passed ? 'bg-green-50' : 'bg-red-50' %>">
      <div class="flex">
        <div class="flex-shrink-0">
          <% if @settlement.verification_passed %>
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          <% else %>
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          <% end %>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium <%= @settlement.verification_passed ? 'text-green-800' : 'text-red-800' %>">
            <%= @settlement.verification_passed ? '검증 완료' : '검증 실패' %>
          </p>
          <p class="text-sm <%= @settlement.verification_passed ? 'text-green-700' : 'text-red-700' %>">
            <%= @settlement.verification_notes %>
          </p>
          <p class="text-xs text-gray-500 mt-1">
            검증 시간: <%= @settlement.verified_at.strftime('%Y-%m-%d %H:%M:%S') %>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- 상태 업데이트 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
  <h2 class="text-lg font-medium text-gray-900 mb-4">상태 업데이트</h2>

  <%= form_with model: @settlement, url: admin_settlement_path(@settlement), method: :patch, local: true do |f| %>
    <div class="flex gap-4 items-end">
      <div class="flex-1">
        <%= f.label :status, '상태', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.select :status,
            options_for_select(Settlement.statuses.map { |k, v| [k.humanize, k] }, @settlement.status),
            {},
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
      </div>

      <div>
        <%= f.submit '업데이트', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700' %>
      </div>
    </div>
  <% end %>
</div>

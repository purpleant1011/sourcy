<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">제품</h1>
    <p class="mt-2 text-gray-600">카탈로그 제품 관리</p>
  </div>
  <%= link_to '새 제품 추가', new_admin_catalog_product_path,
      class: 'inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700',
      data: { turbo_frame: dom_id(CatalogProduct.new) } %>
</div>

<!-- 필터 및 검색 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <%= form_with url: admin_catalog_products_path, method: :get, local: true,
      class: 'flex gap-4 items-end' do |f| %>
    <div class="flex-1">
      <%= f.label :search, '검색', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.text_field :search, value: params[:search],
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1">
      <%= f.label :status, '상태', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :status, options_for_select(CatalogProduct.statuses.map { |k, v| [k.humanize, k] }, params[:status]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div>
      <%= f.submit '검색', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700' %>
    </div>
  <% end %>
</div>

<!-- 제품 목록 -->
<%= turbo_frame_tag 'catalog_products' do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제품명</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">가격</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마진</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">KC 인증</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
          </tr>
        </thead>

        <tbody class="bg-white divide-y divide-gray-200">
          <% @catalog_products.each do |product| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="h-10 w-10 flex-shrink-0">
                    <% if product.processed_images.any? %>
                      <img class="h-10 w-10 rounded-full object-cover"
                           src="<%= product.processed_images.first[:original_image_url] %>"
                           alt="">
                    <% else %>
                      <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    <% end %>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">
                      <%= link_to product.translated_title.truncate(50),
                          admin_catalog_product_path(product),
                          data: { turbo: true } %>
                    </div>
                    <div class="text-sm text-gray-500">
                      <%= product.source_product&.original_title&.truncate(30) %>
                    </div>
                  </div>
                </div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= number_to_currency(product.base_price_krw / 100.0, precision: 0, unit: '₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="<%= product.margin_percent >= 30 ? 'text-green-600' : product.margin_percent >= 20 ? 'text-yellow-600' : 'text-red-600' %>">
                  <%= product.margin_percent %>%
                </span>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case product.kc_cert_status %>
                <% when :approved %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    승인
                  </span>
                <% when :exempted %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    면제
                  </span>
                <% when :pending %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    대기
                  </span>
                <% when :rejected %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    거부
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    알 수 없음
                  </span>
                <% end %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case product.status %>
                <% when :listed %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    등록됨
                  </span>
                <% when :paused %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    일시중지
                  </span>
                <% when :draft %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    초안
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    보관
                  </span>
                <% end %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to '수정', edit_admin_catalog_product_path(product),
                    class: 'text-blue-600 hover:text-blue-900 mr-3',
                    data: { turbo: true } %>
                <%= link_to '삭제', admin_catalog_product_path(product),
                    method: :delete,
                    data: { turbo_confirm: '정말 삭제하시겠습니까?', turbo_method: :delete },
                    class: 'text-red-600 hover:text-red-900' %>
              </td>
            </tr>
          <% end %>

          <% if @catalog_products.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">제품이 없습니다</h3>
                  <p class="mt-1 text-sm text-gray-500">새 제품을 추가해주세요.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- 페이지네이션 -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <div class="text-sm text-gray-700">
        총 <%= @catalog_products.total_count %>개 중 <%= @catalog_products.offset_value + 1 %> - <%= [@catalog_products.offset_value + @catalog_products.length, @catalog_products.total_count].min %>개 표시
      </div>

      <div class="flex gap-2">
        <% unless @catalog_products.first_page? %>
          <%= link_to '이전', url_for(page: params[:page].to_i - 1, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'catalog_products' } %>
        <% end %>

        <% unless @catalog_products.last_page? %>
          <%= link_to '다음', url_for(page: params[:page].to_i + 1, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'catalog_products' } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

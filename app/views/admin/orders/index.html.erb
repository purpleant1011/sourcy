<div class="mb-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">주문</h1>
    <p class="mt-2 text-gray-600">주문 관리</p>
  </div>
</div>

<!-- 필터 및 검색 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <%= form_with url: admin_orders_path, method: :get, local: true,
      class: 'flex gap-4 items-end' do |f| %>
    <div class="flex-1">
      <%= f.label :search, '검색', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.text_field :search, value: params[:search],
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1">
      <%= f.label :status, '상태', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :status,
          options_for_select(Order.order_statuses.map { |k, v| [k.humanize, k] }, params[:status]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1">
      <%= f.label :date_range, '날짜', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :date_range,
          options_for_select([['최근 7일', '7d'], ['최근 30일', '30d'], ['최근 90일', '90d']], params[:date_range]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div>
      <%= f.submit '검색', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700' %>
    </div>
  <% end %>
</div>

<!-- 주문 목록 -->
<%= turbo_frame_tag 'orders' do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문번호</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">고객</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마켓</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">금액</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">날짜</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
          </tr>
        </thead>

        <tbody class="bg-white divide-y divide-gray-200">
          <% @orders.each do |order| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to order.order_number, admin_order_path(order),
                      data: { turbo: true } %>
                </div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.customer_name || '-' %>
                <div class="text-xs text-gray-400"><%= order.customer_email %></div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.marketplace.humanize %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= number_to_currency(order.total_amount_krw / 100.0, precision: 0, unit: '₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case order.status %>
                <% when :pending %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    대기
                  </span>
                <% when :confirmed %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    확정
                  </span>
                <% when :shipped %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    배송중
                  </span>
                <% when :delivered %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    배송완료
                  </span>
                <% when :cancelled %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    취소
                  </span>
                <% when :refunded %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    환불
                  </span>
                <% end %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.created_at.strftime('%Y-%m-%d %H:%M') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to '상세', admin_order_path(order),
                    class: 'text-blue-600 hover:text-blue-900',
                    data: { turbo: true } %>
              </td>
            </tr>
          <% end %>

          <% if @orders.empty? %>
            <tr>
              <td colspan="7" class="px-6 py-12 text-center">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">주문이 없습니다</h3>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- 페이지네이션 -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <div class="text-sm text-gray-700">
    <!-- 페이지네이션 -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <div class="text-sm text-gray-700">
        총 <%= @pagy.count %>개 중 <%= @pagy.from %> - <%= @pagy.to %>개 표시
      </div>
      <div class="flex gap-2">
        <% if @pagy.prev %>
          <%= link_to '이전', url_for(page: @pagy.prev, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50' %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to '다음', url_for(page: @pagy.next, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50' %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

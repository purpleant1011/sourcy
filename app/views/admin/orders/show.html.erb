<div class="mb-6">
  <%= link_to admin_orders_path,
      class: 'inline-flex items-center text-sm text-gray-600 hover:text-gray-900',
      data: { turbo: true } do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    목록으로 돌아가기
  <% end %>
</div>

<!-- 주문 상세 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">주문 <%= @order.order_number %></h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @order.created_at.strftime('%Y년 %m월 %d일 %H:%M') %>
      </p>
    </div>

    <div class="flex gap-2">
      <%= form_with model: @order, url: admin_order_path(@order), method: :patch, local: true do |f| %>
        <%= f.select :status,
            options_for_select(Order.statuses.map { |k, v| [k.humanize, k] }, @order.status),
            { class: 'rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-2' } %>
        <%= f.submit '업데이트', class: 'ml-2 px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700' %>
      <% end %>
    </div>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- 주문 정보 -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-gray-900">주문 정보</h3>

        <div>
          <label class="block text-sm font-medium text-gray-700">상태</label>
          <p class="mt-1">
            <% case @order.status %>
            <% when :pending %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                대기
              </span>
            <% when :confirmed %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                확정
              </span>
            <% when :shipped %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                배송중
              </span>
            <% when :delivered %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                배송완료
              </span>
            <% when :cancelled %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                취소
              </span>
            <% when :refunded %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                환불
              </span>
            <% end %>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">마켓플레이스</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.marketplace.humanize %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">총 금액</label>
          <p class="mt-1 text-2xl font-bold text-gray-900">
            <%= number_to_currency(@order.total_amount_krw / 100.0, precision: 0, unit: '₩') %>
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">배송비</label>
            <p class="mt-1 text-sm text-gray-900">
              <%= number_to_currency(@order.shipping_fee_krw / 100.0, precision: 0, unit: '₩') %>
            </p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">관세</label>
            <p class="mt-1 text-sm text-gray-900">
              <%= number_to_currency(@order.duty_amount_krw / 100.0, precision: 0, unit: '₩') %>
            </p>
          </div>
        </div>
      </div>

      <!-- 고객 정보 -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-gray-900">고객 정보</h3>

        <div>
          <label class="block text-sm font-medium text-gray-700">이름</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.customer_name || '-' %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">이메일</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.customer_email %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">연락처</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.customer_phone || '-' %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">배송지</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.shipping_address || '-' %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 주문 항목 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">주문 항목</h3>
  </div>

  <div class="p-6">
    <% if @items.any? %>
      <div class="space-y-4">
        <% @items.each do |item| %>
          <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
            <div class="flex items-center">
              <div class="h-12 w-12 rounded bg-gray-200 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">
                  <%= item.catalog_product&.translated_title || '알 수 없는 제품' %>
                </p>
                <p class="text-sm text-gray-500">수량: <%= item.quantity %></p>
              </div>
            </div>

            <div class="text-right">
              <p class="text-sm font-medium text-gray-900">
                <%= number_to_currency(item.unit_price_krw / 100.0, precision: 0, unit: '₩') %>
              </p>
              <p class="text-xs text-gray-500">
                소계: <%= number_to_currency((item.unit_price_krw * item.quantity) / 100.0, precision: 0, unit: '₩') %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 text-center py-4">주문 항목이 없습니다.</p>
    <% end %>
  </div>
</div>

<!-- 배송 정보 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">배송 정보</h3>
  </div>

  <div class="p-6">
    <% if @shipment %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">배송사</label>
          <p class="mt-1 text-sm text-gray-900"><%= @shipment.carrier || '-' %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">송장번호</label>
          <p class="mt-1 text-sm text-gray-900">
            <% if @shipment.tracking_number.present? %>
              <%= link_to @shipment.tracking_number, "https://tracker.delivery/#/#{@shipment.tracking_number}",
                  target: '_blank',
                  class: 'text-blue-600 hover:text-blue-900' %>
            <% else %>
              -
            <% end %>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">배송일</label>
          <p class="mt-1 text-sm text-gray-900">
            <%= @shipment.shipped_at&.strftime('%Y-%m-%d %H:%M') || '-' %>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">배송 상태</label>
          <p class="mt-1 text-sm text-gray-900">
            <%= @shipment.status.humanize %>
          </p>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 text-center py-4">배송 정보가 없습니다.</p>
    <% end %>
  </div>
</div>

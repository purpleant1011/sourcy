<div class="mb-6">
  <%= link_to admin_orders_path, class: 'inline-flex items-center text-sm text-gray-600 hover:text-gray-900' do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    <span>목록으로 돌아가기</span>
  <% end %>
</div>

<!-- 주문 상세 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">주문 #<%= @order.external_order_id %></h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @order.ordered_at.strftime('%Y년 %m월 %d일 %H:%M') %>
      </p>
    </div>

    <div class="flex gap-2 items-center">
      <%= form_with model: @order, url: admin_order_path(@order), method: :patch, local: true, class: 'flex items-center gap-2' do |f| %>
        <%= f.select :order_status,
            options_for_select(Order.order_statuses.map { |k, _v| [k.humanize, k] }, @order.order_status),
            {},
            class: 'rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2' %>
        <%= f.submit '업데이트', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 cursor-pointer' %>
      <% end %>
    </div>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-2 gap-6">
      <!-- 주문 정보 -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-gray-900">주문 정보</h3>

        <div>
          <label class="block text-sm font-medium text-gray-500">상태</label>
          <p class="mt-1">
            <% status_classes = case @order.order_status
              when 'pending' then 'bg-gray-100 text-gray-800'
              when 'paid' then 'bg-blue-100 text-blue-800'
              when 'preparing' then 'bg-yellow-100 text-yellow-800'
              when 'shipped' then 'bg-teal-100 text-teal-800'
              when 'delivered' then 'bg-green-100 text-green-800'
              when 'canceled' then 'bg-red-100 text-red-800'
              when 'returned' then 'bg-purple-100 text-purple-800'
              else 'bg-gray-100 text-gray-800'
              end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_classes %>">
              <%= @order.order_status.humanize %>
            </span>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">마켓플레이스</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.marketplace_platform.humanize %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">총 금액</label>
          <p class="mt-1 text-2xl font-bold text-gray-900">
            <%= number_to_currency(@order.total_amount_krw / 100.0, precision: 0, unit: '₩') %>
          </p>
        </div>

        <% if @order.shipping_memo.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-500">배송 메모</label>
            <p class="mt-1 text-sm text-gray-900"><%= @order.shipping_memo %></p>
          </div>
        <% end %>
      </div>

      <!-- 구매자 정보 (암호화) -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-gray-900">구매자 정보</h3>

        <div>
          <label class="block text-sm font-medium text-gray-500">구매자명</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.buyer_name_ciphertext.present? ? '(암호화됨)' : '-' %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">연락처</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.buyer_contact_ciphertext.present? ? '(암호화됨)' : '-' %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">배송지</label>
          <p class="mt-1 text-sm text-gray-900"><%= @order.buyer_address_ciphertext.present? ? '(암호화됨)' : '-' %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 주문 항목 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">주문 항목</h3>
  </div>

  <div class="overflow-x-auto">
    <% if @items.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제품</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">수량</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">단가</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">소계</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @items.each do |item| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900">
                  <%= item.product_name_snapshot %>
                </div>
                <% if item.catalog_product %>
                  <div class="text-xs text-gray-500">
                    <%= link_to '카탈로그 보기', admin_catalog_product_path(item.catalog_product), class: 'text-blue-600 hover:text-blue-800' %>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= item.quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= number_to_currency(item.unit_price_krw / 100.0, precision: 0, unit: '₩') %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium text-right">
                <%= number_to_currency((item.unit_price_krw * item.quantity) / 100.0, precision: 0, unit: '₩') %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-6 text-center">
        <p class="text-sm text-gray-500">주문 항목이 없습니다.</p>
      </div>
    <% end %>
  </div>
</div>

<!-- 배송 정보 -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-semibold text-gray-900">배송 정보</h3>
  </div>

  <div class="p-6">
    <% if @shipment %>
      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-500">배송사</label>
          <p class="mt-1 text-sm text-gray-900"><%= @shipment.shipping_provider.humanize %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">송장번호</label>
          <p class="mt-1 text-sm text-gray-900">
            <% if @shipment.tracking_number.present? %>
              <span class="text-blue-600 font-mono"><%= @shipment.tracking_number %></span>
            <% else %>
              -
            <% end %>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">발송일</label>
          <p class="mt-1 text-sm text-gray-900">
            <%= @shipment.shipped_at&.strftime('%Y-%m-%d %H:%M') || '-' %>
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-500">배송 상태</label>
          <p class="mt-1">
            <% ship_status_classes = case @shipment.shipping_status
              when 'ready' then 'bg-gray-100 text-gray-800'
              when 'in_transit' then 'bg-blue-100 text-blue-800'
              when 'delivered' then 'bg-green-100 text-green-800'
              when 'exception' then 'bg-red-100 text-red-800'
              else 'bg-gray-100 text-gray-800'
              end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= ship_status_classes %>">
              <%= @shipment.shipping_status.humanize %>
            </span>
          </p>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 text-center py-4">배송 정보가 없습니다.</p>
    <% end %>
  </div>
</div>

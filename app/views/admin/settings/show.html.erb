<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">설정</h1>
  <p class="mt-2 text-gray-600">계정 및 팀 설정 관리</p>
</div>

<div class="space-y-8">
  <!-- 계정 기본 설정 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">계정 설정</h2>

    <% if @account %>
      <%= form_with(model: @account, url: admin_settings_path, method: :patch, class: "space-y-4") do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :name, "계정명", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
          <div>
            <%= f.label :slug, "슬러그", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-gray-50", disabled: true %>
          </div>
        </div>

        <div class="mt-2">
          <span class="text-xs text-gray-500">플랜: <strong><%= @account.plan %></strong></span>
        </div>

        <div class="flex justify-end">
          <%= f.submit "저장", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-gray-500">등록된 계정이 없습니다.</p>
    <% end %>
  </div>

  <!-- 팀원 관리 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">팀원 관리</h2>
    <% if @memberships.present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">이메일</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">역할</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @memberships.each do |membership| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900"><%= membership.user&.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= membership.user&.email %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= membership.role %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">등록된 팀원이 없습니다.</p>
    <% end %>
  </div>

  <!-- API 자격 증명 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">API 자격 증명 (Chrome Extension)</h2>
    <% if @api_credentials.present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">생성일</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">만료일</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">마지막 사용</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @api_credentials.each do |cred| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900"><%= cred.created_at.strftime('%Y-%m-%d') %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= cred.expires_at&.strftime('%Y-%m-%d') || '무기한' %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= cred.last_used_at&.strftime('%Y-%m-%d %H:%M') || '미사용' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">등록된 API 자격 증명이 없습니다.</p>
    <% end %>
  </div>

  <!-- 마켓플레이스 계정 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">마켓플레이스 계정</h2>
    <% if @marketplace_accounts.present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">상점명</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">플랫폼</th>
            <th class="px-4 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @marketplace_accounts.each do |ma| %>
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= ma.shop_name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= ma.provider %></td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= ma.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= ma.status %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">등록된 마켓플레이스 계정이 없습니다.</p>
    <% end %>
  </div>
</div>

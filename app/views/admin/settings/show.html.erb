<div class="space-y-8">
  <!-- 계정 설정 섹션 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">계정 설정</h2>

    <% if @account %>
      <%= form_with(model: @account, url: admin_settings_path, method: :patch, class: "space-y-4") do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :name, "계정명", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :company_name, "회사명", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :company_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :business_number, "사업자등록번호", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :business_number, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :contact_phone, "연락처", class: "block text-sm font-medium text-gray-700" %>
            <%= f.telephone_field :contact_phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :contact_email, "이메일", class: "block text-sm font-medium text-gray-700" %>
            <%= f.email_field :contact_email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
        </div>

        <div class="flex justify-end">
          <%= f.submit "저장", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-gray-500">등록된 계정이 없습니다.</p>
    <% end %>
  </div>

  <!-- 팀원 관리 섹션 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">팀원 관리</h2>

    <% if @memberships.present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">이름</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">이메일</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">역할</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @memberships.each do |membership| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= membership.user.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= membership.user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= membership.role.capitalize %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= membership.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= membership.is_active ? '활성' : '비활성' %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">팀원이 없습니다.</p>
    <% end %>
  </div>

  <!-- API 자격 증명 섹션 -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">API 자격 증명</h2>

    <!-- 새 자격 증명 추가 폼 -->
    <div class="mb-6 p-4 bg-gray-50 rounded-lg">
      <h3 class="text-sm font-medium text-gray-900 mb-3">새 자격 증명 추가</h3>

      <%= form_with(model: @account.api_credentials.build, url: create_credential_admin_settings_path, class: "space-y-3") do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div>
            <%= f.label :provider, "제공자", class: "block text-xs font-medium text-gray-700" %>
            <%= f.select :provider,
                ApiCredential.providers.keys.map { |k| [k.titleize, k] },
                {},
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :access_key, "Access Key", class: "block text-xs font-medium text-gray-700" %>
            <%= f.text_field :access_key, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :secret_key, "Secret Key", class: "block text-xs font-medium text-gray-700" %>
            <%= f.password_field :secret_key, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div class="md:col-span-3">
            <%= f.label :additional_config, "추가 설정 (JSON)", class: "block text-xs font-medium text-gray-700" %>
            <%= f.text_area :additional_config, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>

          <div class="md:col-span-3">
            <%= f.label :is_active, class: "flex items-center" do %>
              <%= f.check_box :is_active, class: "rounded border-gray-300 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
              <span class="ml-2 text-xs text-gray-700">활성화</span>
            <% end %>
          </div>
        </div>

        <div class="flex justify-end">
          <%= f.submit "추가", class: "inline-flex justify-center py-1.5 px-3 border border-transparent shadow-sm text-xs font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    </div>

    <!-- 기존 자격 증명 목록 -->
    <% if @api_credentials.present? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제공자</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Access Key</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
            <th class="px-6 py-3 bg-gray-50 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">생성일</th>
            <th class="px-6 py-3 bg-gray-50 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @api_credentials.each do |credential| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= provider_badge_class(credential.provider) %>">
                  <%= credential.provider %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-mono">
                <%= mask_key(credential.access_key) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= credential.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= credential.is_active ? '활성' : '비활성' %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= l(credential.created_at, format: :short) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= button_to "삭제",
                    destroy_credential_admin_settings_path(id: credential.id),
                    method: :delete,
                    data: { confirm: "정말 이 API 자격 증명을 삭제하시겠습니까?" },
                    class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">등록된 API 자격 증명이 없습니다.</p>
    <% end %>
  </div>
</div>

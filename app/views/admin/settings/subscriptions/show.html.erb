<%# frozen_string_literal: true %>

<% content_for :title, "구독 및 결제" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">구독 및 결제</h1>
      <p class="text-sm text-gray-500 mt-1">구독 플랜과 결제를 관리하세요</p>
    </div>
  </div>

  <!-- Navigation Tabs -->
  <%= turbo_frame_tag "settings_navigation" do %>
    <nav class="flex space-x-4 border-b border-gray-200">
      <%= link_to admin_accounts_path,
                  class: "px-3 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" do %>
        일반 정보
      <% end %>
      <%= link_to admin_teams_path,
                  class: "px-3 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" do %>
        팀 관리
      <% end %>
      <%= link_to admin_subscription_path,
                  class: "px-3 py-2 text-sm font-medium border-b-2 border-indigo-500 text-indigo-600" do %>
        구독 및 결제
      <% end %>
    </nav>
  <% end %>

  <!-- Current Subscription -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-medium text-gray-900">현재 구독</h3>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @subscription.status == 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
          <%= @subscription.status == 'active' ? '활성' : '비활성' %>
        </span>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Plan Details -->
        <div class="space-y-4">
          <div>
            <div class="text-sm text-gray-500">플랜</div>
            <div class="mt-1 text-xl font-semibold text-gray-900">
              <%= @subscription.plan&.humanize || 'Free' %>
            </div>
          </div>

          <div>
            <div class="text-sm text-gray-500">결제 주기</div>
            <div class="mt-1 text-lg font-medium text-gray-900">
              <%= @subscription.billing_cycle&.humanize || '월간' %>
            </div>
          </div>

          <% if @subscription.card_last4.present? %>
            <div>
              <div class="text-sm text-gray-500">결제 카드</div>
              <div class="mt-1 text-lg font-medium text-gray-900">
                <%= @subscription.card_brand&.upcase %> •••• <%= @subscription.card_last4 %>
              </div>
            </div>
          <% end %>

          <div>
            <div class="text-sm text-gray-500">다음 청구일</div>
            <div class="mt-1 text-lg font-medium text-gray-900">
              <%= @subscription.next_billing_date&.strftime('%Y년 %m월 %d일') || 'N/A' %>
            </div>
          </div>
        </div>

        <!-- Usage Stats -->
        <div class="space-y-4">
          <h4 class="text-sm font-medium text-gray-900">이번 달 사용량</h4>

          <div class="space-y-3">
            <div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">소스 제품</span>
                <span class="font-medium text-gray-900">
                  <%= @usage_stats[:source_products] %>
                </span>
              </div>
              <div class="mt-1 bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= calculate_usage_percent(@usage_stats[:source_products], 1000) %>%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">카탈로그 제품</span>
                <span class="font-medium text-gray-900">
                  <%= @usage_stats[:catalog_products] %>
                </span>
              </div>
              <div class="mt-1 bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= calculate_usage_percent(@usage_stats[:catalog_products], 1000) %>%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">API 호출</span>
                <span class="font-medium text-gray-900">
                  <%= number_with_delimiter(@usage_stats[:api_calls]) %>
                </span>
              </div>
              <div class="mt-1 bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= calculate_usage_percent(@usage_stats[:api_calls], 10000) %>%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">저장소</span>
                <span class="font-medium text-gray-900">
                  <%= @usage_stats[:storage_mb] %> MB
                </span>
              </div>
              <div class="mt-1 bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= calculate_usage_percent(@usage_stats[:storage_mb], 1000) %>%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="mt-6 pt-6 border-t border-gray-200 flex space-x-3">
        <% if @subscription.status == 'active' %>
          <%= button_to cancel_admin_subscription_path(@subscription),
                      method: :post,
                      data: { turbo_confirm: "정말 구독을 취소하시겠습니까?" },
                      class: "inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" do %>
            구독 취소
          <% end %>
        <% else %>
          <%= button_to resume_admin_subscription_path(@subscription),
                      method: :post,
                      class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" do %>
            구독 재개
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Available Plans -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-6">사용 가능한 플랜</h3>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
        <% @available_plans.each do |plan| %>
          <div class="border rounded-lg p-6 <%= @subscription.plan == plan[:id] ? 'border-indigo-500 ring-2 ring-indigo-500' : 'border-gray-200' %>">
            <div class="text-center">
              <div class="text-lg font-semibold text-gray-900">
                <%= plan[:name] %>
              </div>
              <div class="mt-2">
                <% if plan[:price] %>
                  <span class="text-3xl font-bold text-gray-900">
                    <%= number_to_currency(plan[:price], unit: '₩', precision: 0) %>
                  </span>
                  <span class="text-sm text-gray-500">/월</span>
                <% else %>
                  <span class="text-3xl font-bold text-gray-900">문의</span>
                <% end %>
              </div>

              <% if @subscription.plan == plan[:id] %>
                <span class="mt-3 inline-block px-3 py-1 text-sm font-medium rounded-full bg-indigo-100 text-indigo-800">
                  현재 플랜
                </span>
              <% else %>
                <%= form_with url: change_plan_admin_subscription_path(@subscription),
                              method: :post,
                              data: { turbo_frame: "subscription_form" },
                              class: "mt-4" do |f| %>
                  <%= hidden_field_tag :plan, plan[:id] %>
                  <%= f.submit "변경",
                               class: "w-full inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
                <% end %>
              <% end %>

              <ul class="mt-6 space-y-2 text-left">
                <% plan[:features].each do |feature| %>
                  <li class="flex items-start">
                    <%= heroicon 'check', variant: :solid, class: "h-5 w-5 text-green-500 mr-2 flex-shrink-0" %>
                    <span class="text-sm text-gray-600"><%= feature %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Billing History -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">청구 내역</h3>

      <% if @billing_history.any? %>
        <div class="overflow-hidden">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">청구일</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">설명</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">금액</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @billing_history.each do |billing| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= billing[:date].strftime('%Y년 %m월 %d일') %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900">
                    <%= billing[:description] %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= number_to_currency(billing[:amount], unit: '₩', precision: 0) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= billing[:status] == 'paid' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                      <%= billing[:status] == 'paid' ? '결제 완료' : '대기 중' %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500">
          청구 내역이 없습니다.
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Helper method for usage percentage %>
<% def calculate_usage_percent(current, max)
   return 0 if max.zero?
   [(current.to_f / max * 100).to_i, 100].min
 end %>

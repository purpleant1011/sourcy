<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">리스팅</h1>
    <p class="mt-2 text-gray-600">마켓플레이스 리스팅 관리</p>
  </div>
  <%= link_to '새 리스팅 추가', new_admin_marketplace_listing_path,
      class: 'inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700',
      data: { turbo: true } %>
</div>

<!-- 필터 및 검색 -->
<div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 mb-6">
  <%= form_with url: admin_marketplace_listings_path, method: :get, local: true,
      class: 'flex gap-4 items-end' do |f| %>
    <div class="flex-1">
      <%= f.label :search, '검색', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.text_field :search, value: params[:search],
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1">
      <%= f.label :marketplace, '마켓플레이스', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :marketplace,
          options_for_select(MarketplaceListing.marketplaces.map { |k, v| [k.humanize, k] }, params[:marketplace]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div class="flex-1">
      <%= f.label :status, '상태', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :status,
          options_for_select(MarketplaceListing.statuses.map { |k, v| [k.humanize, k] }, params[:status]),
          { include_blank: '전체' },
          class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm' %>
    </div>

    <div>
      <%= f.submit '검색', class: 'px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700' %>
    </div>
  <% end %>
</div>

<!-- 리스팅 목록 -->
<%= turbo_frame_tag 'marketplace_listings' do %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마켓</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제품</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">가격</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">재고</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
          </tr>
        </thead>

        <tbody class="bg-white divide-y divide-gray-200">
          <% @listings.each do |listing| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-3">
                    <span class="text-xs font-medium text-blue-800">
                      <%= listing.marketplace.to_s.upcase.first(2) %>
                    </span>
                  </div>
                  <div class="text-sm font-medium text-gray-900">
                    <%= listing.marketplace.humanize %>
                  </div>
                </div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">
                  <%= link_to listing.catalog_product.translated_title.truncate(40),
                      admin_marketplace_listing_path(listing),
                      data: { turbo: true } %>
                </div>
                <div class="text-sm text-gray-500">
                  <%= listing.marketplace_category_code || '-' %>
                </div>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= number_to_currency(listing.listing_price_krw / 100.0, precision: 0, unit: '₩') %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= listing.stock_quantity || 0 %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case listing.status %>
                <% when :listed %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    등록됨
                  </span>
                <% when :paused %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    일시중지
                  </span>
                <% when :draft %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    초안
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    실패
                  </span>
                <% end %>
              </td>

              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to '수정', edit_admin_marketplace_listing_path(listing),
                    class: 'text-blue-600 hover:text-blue-900 mr-3',
                    data: { turbo: true } %>
                <%= link_to '삭제', admin_marketplace_listing_path(listing),
                    method: :delete,
                    data: { turbo_confirm: '정말 삭제하시겠습니까?', turbo_method: :delete },
                    class: 'text-red-600 hover:text-red-900' %>
              </td>
            </tr>
          <% end %>

          <% if @listings.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">리스팅이 없습니다</h3>
                  <p class="mt-1 text-sm text-gray-500">새 리스팅을 추가해주세요.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- 페이지네이션 -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <div class="text-sm text-gray-700">
        총 <%= @listings.total_count %>개 중 <%= @listings.offset_value + 1 %> - <%= [@listings.offset_value + @listings.length, @listings.total_count].min %>개 표시
      </div>

      <div class="flex gap-2">
        <% unless @listings.first_page? %>
          <%= link_to '이전', url_for(page: params[:page].to_i - 1, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'marketplace_listings' } %>
        <% end %>

        <% unless @listings.last_page? %>
          <%= link_to '다음', url_for(page: params[:page].to_i + 1, status: params[:status], search: params[:search]),
              class: 'px-3 py-1 border border-gray-300 rounded text-sm text-gray-600 hover:bg-gray-50',
              data: { turbo_frame: 'marketplace_listings' } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
